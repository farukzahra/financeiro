POSTGRES_PASSWORD=troque-esta-senha
AUTH_SECRET=gere-um-segredo-longo-e-estavel

# Use false enquanto acessar por http://IP.
# Troque para true quando usar dominio HTTPS.
AUTH_COOKIE_SECURE=false

# Use seu dominio quando o DNS ja estiver apontando para a VPS.
# Exemplo: SITE_ADDRESS=financeiro.seudominio.com
# Para testar sem dominio/HTTPS, deixe :80.
SITE_ADDRESS=:80
